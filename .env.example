# Copy this file to .env and set your Subscan API key.
# This key is required for all Subscan API requests.
# Do NOT commit your .env file to version control — it is already in .gitignore.
#
# The variable is NOT prefixed with VITE_ so the key is NEVER baked into the browser bundle.
# - Dev:        read by vite.config.js (Node context) and injected into Vite's dev proxy.
# - Production: set this as an Environment Variable in the Vercel dashboard.
#               The serverless proxy at api/[...proxy].js injects it server-side.
#
# Optional: restrict which upstream hostnames the proxy will forward to.
SUBSCAN_API_KEY=
PROXY_ALLOWLIST=enjin.api.subscan.io
